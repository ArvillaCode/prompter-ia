{
  "name": "proprompter-ai",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "vercel dev --listen 3001",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:api\"",
    "build": "vite build",
    "preview": "vite preview",
    "db:migrate": "tsx api/db/migrate.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.30.0",
    "@libsql/client": "^0.17.4",
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.3",
    "lucide-react": "^0.554.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.5.2",
    "concurrently": "^10.0.3",
    "postcss": "^8.5.19",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.23.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
